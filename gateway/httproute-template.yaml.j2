apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {{ deployment_id }}-route
  namespace: {{ namespace }}
  labels:
    deployhub.io/project: "{{ project_name }}"
    deployhub.io/deployment: "{{ deployment_id }}"
spec:
  parentRefs:
    - name: deployhub-gateway
      namespace: deployhub-system
  hostnames:
    # Host-based routing using wildcard domains (*.deployhub.io is handled by Gateway)
    - "{{ project_name }}.deployhub.io"
  rules:
    - backendRefs:
        - name: {{ service_name }}
          port: {{ service_port }}
